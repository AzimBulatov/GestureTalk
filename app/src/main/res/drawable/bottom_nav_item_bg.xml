<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Выбранная вкладка: небольшой круг внутри ячейки -->
    <item android:state_checked="true">
        <!-- Симметричные отступы, чтобы круг был максимально близок к идеальному -->
        <inset
            android:insetLeft="9dp"
            android:insetRight="9dp"
            android:insetTop="9dp"
            android:insetBottom="9dp">
            <shape android:shape="oval">
                <solid android:color="@color/accent_primary" />
            </shape>
        </inset>
    </item>

    <!-- Невыбранная вкладка: прозрачный фон -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</selector>
