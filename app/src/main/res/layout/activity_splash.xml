<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background">

    <!-- Декоративные элементы (круги на фоне) -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/splash_circle_decoration"
        android:alpha="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp" />

    <View
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@drawable/splash_circle_decoration"
        android:alpha="0.08"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="-30dp"
        android:layout_marginStart="-30dp" />

    <!-- Логотип/Иконка -->
    <ImageView
        android:id="@+id/logoIcon"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_splash_logo_modern"
        android:contentDescription="@string/app_name"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38" />

    <!-- Название приложения -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GestureTalk"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.02"
        android:fontFamily="sans-serif-medium"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/logoIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Слоган -->
    <TextView
        android:id="@+id/appSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Говорите жестами"
        android:textSize="18sp"
        android:textColor="#CCFFFFFF"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/appName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Индикатор загрузки (точки) -->
    <TextView
        android:id="@+id/loadingDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="• • •"
        android:textSize="28sp"
        android:textColor="#E8F5E9"
        android:letterSpacing="0.3"
        android:layout_marginBottom="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
