<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/surface_light">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Тест Supabase интеграции"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnTestConnection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Тест подключения"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/accent_primary"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/btnSaveGesture"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сохранить тестовый жест"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/accent_primary"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/btnLoadGestures"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Загрузить жесты"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/accent_primary"
        android:textColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Нажмите кнопку для тестирования..."
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:background="@color/white"
            android:padding="16dp"
            android:fontFamily="monospace" />

    </ScrollView>

</LinearLayout>