<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light"
    tools:context=".MainActivity">

    <!-- Нижняя граница области камеры (ниже — панель; навигация не перекрывает кнопки) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/cameraBottomGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.70" />

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cameraBottomGuide"
        app:scaleType="fillCenter" />

    <!-- Processed Preview (миниатюра слева снизу в зоне камеры) -->
    <ImageView
        android:id="@+id/processedPreview"
        android:layout_width="112dp"
        android:layout_height="150dp"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView" />

    <!-- Landmarks Overlay (визуализация 55 точек) -->
    <com.example.gesturetalk.ui.LandmarksOverlayView
        android:id="@+id/landmarksOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView" />

    <!-- Кнопка настроек -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        android:contentDescription="Настройки"
        app:tint="@color/text_primary"
        app:backgroundTint="@color/accent_primary"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Кнопка переключения камеры -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnSwitchCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_rotate"
        android:contentDescription="Переключить камеру"
        app:tint="@color/accent_primary"
        app:backgroundTint="@color/surface_light_alt"
        app:fabSize="mini"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Кнопка информации -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:src="@android:drawable/ic_menu_info_details"
        android:contentDescription="Информация"
        app:tint="@color/accent_primary"
        app:backgroundTint="@color/surface_light_alt"
        app:fabSize="mini"
        app:layout_constraintTop_toBottomOf="@id/btnSwitchCamera"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Кадры / очередь поверх камеры (правый нижний угол; поверх оверлея) -->
    <TextView
        android:id="@+id/tvCameraStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:gravity="end"
        android:lineSpacingExtra="2dp"
        android:text="@string/camera_stats_initial"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:shadowColor="#CC000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="4"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView" />

    <!-- Панель управления: кнопки закреплены снизу, логи сжимаются по высоте; отступ под плавающий bottomNav -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controlsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/surface_light_alt"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="104dp"
        app:layout_constraintTop_toBottomOf="@id/cameraBottomGuide"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCurrentWord"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Покажите жест..."
            android:textColor="@color/text_secondary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <HorizontalScrollView
            android:id="@+id/wordHistoryScroll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/tvCurrentWord"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvWordHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:padding="6dp"
                android:minHeight="36dp"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/logsHeaderLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/wordHistoryScroll"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Логи:"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyLogs"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Копировать"
                android:textSize="10sp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:fillViewport="true"
            android:background="@color/log_bg_light"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/logsHeaderLayout"
            app:layout_constraintBottom_toTopOf="@id/buttonsRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/log_text_light"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp" />

        </ScrollView>

        <LinearLayout
            android:id="@+id/buttonsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="Старт"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="56dp"
                android:text="Очистить"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconGravity="textStart"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        style="@style/Widget.GestureTalk.BottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/bottom_nav_margin_horizontal"
        android:layout_marginEnd="@dimen/bottom_nav_margin_horizontal"
        android:layout_marginBottom="@dimen/bottom_nav_margin_bottom"
        app:itemBackground="@drawable/bottom_nav_item_bg"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress indicator при загрузке модели -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>